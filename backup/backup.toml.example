[paths]
backup_root = "/home/user/Backups"
klonol_bin = "/usr/local/bin/klonol"
klonol_repo = "hungrybluedev/klonol"

[restic]
repository = "b2:your-bucket-name:klonol-backups"
password = "your-restic-encryption-password"

[b2]
account_id = "your-b2-key-id"
account_key = "your-b2-application-key"

[retention]
keep_last = 4

[monitoring]
# Uptime Kuma push monitor URL (optional, leave empty to disable)
push_url = ""

[providers]
list = ["github", "forgejo"]
# Directory names for each provider (must match the folder names in backup_root)
dirs = ["GitHub", "Forgejo"]
